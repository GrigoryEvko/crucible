{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },
  "configurePresets": [
    {
      "name": "default",
      "displayName": "GCC 16.1.1 patched (PR c++/124241 cherry-picked) + libstdc++ 16 (C++26)",
      "binaryDir": "${sourceDir}/build",
      "generator": "Ninja",
      "cacheVariables": {
        "_comment_toolchain": "Patched GCC 16.1.1 + libstdc++ 16 are resolved by cmake/Toolchain-gcc16.cmake. Override the location WITHOUT editing this file: set CRUCIBLE_GCC16_PREFIX=<install-prefix> (binaries at <prefix>/usr/bin/g++-16p, libs at <prefix>/usr/lib64), or CRUCIBLE_CXX=<full-g++-path>. Unset -> falls back to $HOME/.local/gcc16-patched (the canonical dev-box default, so this preset configures verbatim here). The libstdc++ rpath is derived from the same prefix.",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/Toolchain-gcc16.cmake",
        "CMAKE_BUILD_TYPE": "Debug",
        "CRUCIBLE_BENCH": "OFF",
        "CRUCIBLE_WERROR": "ON"
      }
    },
    {
      "name": "analyzer",
      "inherits": "default",
      "displayName": "GCC 16 + -fanalyzer (observational)",
      "binaryDir": "${sourceDir}/build-analyzer",
      "cacheVariables": {
        "CRUCIBLE_ANALYZER": "ON",
        "CRUCIBLE_SANITIZE": "OFF",
        "CRUCIBLE_TSAN": "OFF",
        "CRUCIBLE_BENCH": "OFF",
        "CRUCIBLE_WERROR": "OFF"
      }
    },
    {
      "name": "release",
      "inherits": "default",
      "displayName": "GCC 16 + libstdc++ 16 (C++26, Release)",
      "binaryDir": "${sourceDir}/build-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_FLAGS": "-O1 -march=native -DNDEBUG -g"
      }
    },
    {
      "name": "bench",
      "inherits": "release",
      "displayName": "GCC 16 + libstdc++ 16 (C++26, Bench)",
      "binaryDir": "${sourceDir}/build-bench",
      "cacheVariables": {
        "CRUCIBLE_BENCH": "ON"
      }
    },
    {
      "name": "tsan",
      "inherits": "default",
      "displayName": "GCC 16 + ThreadSanitizer (AxRaceFree)",
      "binaryDir": "${sourceDir}/build-tsan",
      "cacheVariables": {
        "CRUCIBLE_SANITIZE": "OFF",
        "CRUCIBLE_TSAN": "ON"
      }
    }
  ],
  "buildPresets": [
    { "name": "default", "configurePreset": "default", "jobs": 192 },
    { "name": "analyzer", "configurePreset": "analyzer", "jobs": 192 },
    { "name": "release", "configurePreset": "release", "jobs": 192 },
    { "name": "bench",   "configurePreset": "bench", "jobs": 192 },
    { "name": "tsan",    "configurePreset": "tsan", "jobs": 192 }
  ],
  "testPresets": [
    {
      "name": "default",
      "configurePreset": "default",
      "output": { "outputOnFailure": true },
      "execution": { "jobs": 192 }
    },
    {
      "name": "release",
      "configurePreset": "release",
      "output": { "outputOnFailure": true },
      "execution": { "jobs": 192 }
    },
    {
      "name": "analyzer",
      "configurePreset": "analyzer",
      "output": { "outputOnFailure": true },
      "execution": { "jobs": 192 }
    },
    {
      "name": "tsan",
      "configurePreset": "tsan",
      "output": { "outputOnFailure": true },
      "execution": { "jobs": 192 }
    },
    {
      "name": "stress",
      "configurePreset": "default",
      "displayName": "Repeat-until-fail ×50 (race condition detector)",
      "output": { "outputOnFailure": true },
      "execution": {
        "jobs": 192,
        "repeat": { "mode": "until-fail", "count": 50 }
      }
    }
  ]
}
