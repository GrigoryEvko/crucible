{
  "version": 6,
  "cmakeMinimumRequired": { "major": 3, "minor": 25, "patch": 0 },
  "configurePresets": [
    {
      "name": "default",
      "displayName": "GCC 16 + libstdc++ 16 (C++26)",
      "binaryDir": "${sourceDir}/build",
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "$env{HOME}/.local/gcc16/usr/bin/g++",
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXE_LINKER_FLAGS": "-Wl,-rpath,$env{HOME}/.local/gcc16/usr/lib64:$env{HOME}/.local/gcc16/lib64",
        "CMAKE_SHARED_LINKER_FLAGS": "-Wl,-rpath,$env{HOME}/.local/gcc16/usr/lib64:$env{HOME}/.local/gcc16/lib64",
        "CMAKE_MODULE_LINKER_FLAGS": "-Wl,-rpath,$env{HOME}/.local/gcc16/usr/lib64:$env{HOME}/.local/gcc16/lib64",
        "CRUCIBLE_BENCH": "OFF",
        "CRUCIBLE_WERROR": "ON"
      }
    },
    {
      "name": "analyzer",
      "inherits": "default",
      "displayName": "GCC 16 + -fanalyzer (observational)",
      "binaryDir": "${sourceDir}/build-analyzer",
      "cacheVariables": {
        "CRUCIBLE_ANALYZER": "ON",
        "CRUCIBLE_SANITIZE": "OFF",
        "CRUCIBLE_TSAN": "OFF",
        "CRUCIBLE_BENCH": "OFF",
        "CRUCIBLE_WERROR": "OFF"
      }
    },
    {
      "name": "release",
      "inherits": "default",
      "displayName": "GCC 16 + libstdc++ 16 (C++26, Release)",
      "binaryDir": "${sourceDir}/build-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_CXX_FLAGS": "-O1 -march=native -DNDEBUG -g"
      }
    },
    {
      "name": "bench",
      "inherits": "release",
      "displayName": "GCC 16 + libstdc++ 16 (C++26, Bench)",
      "binaryDir": "${sourceDir}/build-bench",
      "cacheVariables": {
        "CRUCIBLE_BENCH": "ON"
      }
    },
    {
      "name": "tsan",
      "inherits": "default",
      "displayName": "GCC 16 + ThreadSanitizer (AxRaceFree)",
      "binaryDir": "${sourceDir}/build-tsan",
      "cacheVariables": {
        "CRUCIBLE_SANITIZE": "OFF",
        "CRUCIBLE_TSAN": "ON"
      }
    }
  ],
  "buildPresets": [
    { "name": "default", "configurePreset": "default" },
    { "name": "analyzer", "configurePreset": "analyzer" },
    { "name": "release", "configurePreset": "release" },
    { "name": "bench",   "configurePreset": "bench" },
    { "name": "tsan",    "configurePreset": "tsan" }
  ],
  "testPresets": [
    {
      "name": "default",
      "configurePreset": "default",
      "output": { "outputOnFailure": true },
      "execution": { "jobs": 24 }
    },
    {
      "name": "release",
      "configurePreset": "release",
      "output": { "outputOnFailure": true },
      "execution": { "jobs": 24 }
    },
    {
      "name": "analyzer",
      "configurePreset": "analyzer",
      "output": { "outputOnFailure": true },
      "execution": { "jobs": 24 }
    },
    {
      "name": "tsan",
      "configurePreset": "tsan",
      "output": { "outputOnFailure": true },
      "execution": { "jobs": 24 }
    },
    {
      "name": "stress",
      "configurePreset": "default",
      "displayName": "Repeat-until-fail ×50 (race condition detector)",
      "output": { "outputOnFailure": true },
      "execution": { "repeat": { "mode": "until-fail", "count": 50 } }
    }
  ]
}
